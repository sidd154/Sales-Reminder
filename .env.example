# ==========================================
# CEO Sales Reminder - Environment Settings (Example)
# ==========================================

# System Settings
MOCK_MODE=True                  # Set to False to run live API calls
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR

# CEO/Recipient Settings
CEO_NAME=Siddhanth
CEO_PHONE=916380915054          # Standard format with country code, no +
CEO_EMAIL=siddhanthsrinivasan@gmail.com

# Zoho CRM API Settings
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_URL=https://www.zohoapis.com
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# Zoho Custom Fields API Names (Map to your Zoho CRM schema)
ZOHO_FIELD_LEAD_BUDGET=Monthly_Budget
ZOHO_FIELD_LEAD_MRR=Expected_MRR
ZOHO_FIELD_LEAD_SERVICE=Service_Interested
ZOHO_FIELD_DEAL_LOSS_REASON=Loss_Reason
ZOHO_FIELD_CALL_OUTCOME=Call_Outcome
ZOHO_FIELD_NEXT_FOLLOWUP=Next_Follow_up_Date

# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Meta WhatsApp Cloud API Settings
WHATSAPP_API_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_TEMPLATE_NAME=approved

# Resend Email Settings
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=hi@pixelsoft.in
EMAIL_TO=siddhanthsrinivasan@gmail.com

# Alert Thresholds
ALERT_SLA_HOURS=24
ALERT_HIGH_VALUE_LEAD_BUDGET=100000     # Budget in INR to flag high-value lead
ALERT_HIGH_VALUE_DEAL_VALUE=300000      # Deal value in INR to flag high-value lost deal
ALERT_PROPOSAL_PENDING_DAYS=7           # Proposal untouched days threshold
ALERT_COMPLIANCE_TARGET=80              # Target follow-up compliance percentage (0-100)
ALERT_PIPELINE_DROP_PERCENT=10          # Pipeline drop percentage to trigger alert
